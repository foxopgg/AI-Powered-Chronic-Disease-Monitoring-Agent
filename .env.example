# ============================================================
# VitalSense AI — IBM Cloud Configuration
# Copy this file to .env and fill in your IBM Cloud credentials
# ============================================================

# 1. IBM Cloud API Key (from IAM > API Keys)
IBM_API_KEY=e8523a04-47e5-4823-81eb-895cc14afb3f

# 2. watsonx.ai Project ID (from IBM watsonx.ai Studio > Manage > General)
WATSONX_PROJECT_ID=5d7d0b01-f195-4b8c-ba3c-15a2264bc60a

# 3. Watson Machine Learning Service URL (region-specific)
WATSON_ML_URL=https://us-south.ml.cloud.ibm.com

# 4. IBM watsonx.ai Studio Model ID
IBM_MODEL_ID=meta-llama/llama-3-8b-instruct

# ============================================================
# IBM Cloud Object Storage (COS) — for medical report storage
# ============================================================

# 5. COS Endpoint (region-specific)
#    e.g., s3.us-south.cloud-object-storage.appdomain.cloud
COS_ENDPOINT=s3.us-south.cloud-object-storage.appdomain.cloud

# 6. COS Bucket Name (create in IBM COS console)
COS_BUCKET=vitalsense-reports

# 7. COS Service Instance CRN (from IBM COS > Service credentials > resource_instance_id)
#    e.g., crn:v1:bluemix:public:cloud-object-storage:global:a/...
COS_INSTANCE_ID=crn:v1:bluemix:public:cloud-object-storage:global:a/1dde7ce371ba4ac595d206c78ec7376e:f40bf114-8b4b-4d05-a7c1-c11817e94ee2::

# 8. COS API Key — leave blank to use IBM_API_KEY above
COS_API_KEY=

# ============================================================
# Application Settings
# ============================================================

# 9. Local server port
PORT=3000
