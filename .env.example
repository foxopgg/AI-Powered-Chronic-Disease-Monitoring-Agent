# IBM Cloud Credentials for VitalSense AI

# 1. IBM Cloud API Key
IBM_API_KEY=YOUR_IBM_CLOUD_API_KEY_HERE

# 2. watsonx.ai Project ID
WATSONX_PROJECT_ID=YOUR_WATSONX_PROJECT_ID_HERE

# 3. Watson Machine Learning Service URL
WATSON_ML_URL=https://us-south.ml.cloud.ibm.com

# 4. IBM Granite Model ID
IBM_MODEL_ID=ibm/granite-3-8b-instruct

# 5. Local Server Port
PORT=3000
